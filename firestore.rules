rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper: user is admin if their users/{uid} doc has isAdmin == true
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true ||
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == 'true');
    }

    // OTP verification during registration
    match /otps/{docId} {
      allow read, write: if true;
    }

    // Username to email lookup (needed for login)
    match /usernameLookup/{username} {
      allow read: if true;
      allow create, update: if request.auth != null;
      allow delete: if isAdmin() || (request.auth != null && resource.data.userId == request.auth.uid);
    }

    // Users: any logged-in user can READ all users (for leaderboard, admin calculate points)
    // Unauthenticated read allowed for forgot-password flow (lookup by email/username, check reset limit)
    // Users can WRITE and DELETE their own document (for account surrender); admin can DELETE any user
    match /users/{userId} {
      allow read: if true;
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow delete: if isAdmin() || (request.auth != null && request.auth.uid == userId);
    }

    match /settings/{docId} {
      allow read: if request.auth != null || docId == 'passwordPolicy';
      allow write: if isAdmin();
    }

    match /teams/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /rules/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    match /matches/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Predictions: any logged-in user can READ all (admin needs this for calculate points)
    // Users can CREATE/UPDATE/DELETE their own prediction (delete for account surrender)
    match /predictions/{docId} {
      allow read: if request.auth != null;
      allow create, update: if request.auth != null &&
        request.resource.data.userId == request.auth.uid;
      allow delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }

    // Cricket Insights approvers (admin adds via Program Config; doc id = userId)
    match /insight_approvers/{userId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Cricket Insights: questions (users create; admin/approvers can approve; only admin can delete)
    match /cricket_questions/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if isAdmin() ||
        (request.auth != null && exists(/databases/$(database)/documents/insight_approvers/$(request.auth.uid)));
      allow delete: if isAdmin();
    }

    // Cricket Insights: answers (users answer once per question)
    match /cricket_answers/{docId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.userId == request.auth.uid;
    }
  }
}
